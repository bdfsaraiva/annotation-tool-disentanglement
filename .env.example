# Deployment configuration - Annotation Tool
# ========================================

# Server IP where the application runs
# Local development: localhost
# LAN access: machine IP (example: 192.168.1.100)
SERVER_IP=localhost

# Service ports
FRONTEND_PORT=3721
BACKEND_PORT=8000

# Backend configuration
DATABASE_URL=sqlite:///./data/app.db
# NOTE: must be at least 32 characters
SECRET_KEY=change-me-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Initial admin user (change for production)
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=admin

# CORS origins (auto-extended based on SERVER_IP)
CORS_ORIGINS=["http://localhost:3721","http://127.0.0.1:3721"]

# Frontend configuration
# Docker Compose sets this for the frontend container
REACT_APP_API_URL=http://localhost:8000

# ========================================
# Usage
# ========================================
# 1) Copy this file to .env
#    cp .env.example .env
#
# 2) For LAN access, set SERVER_IP to the host IP
#
# 3) For production, update SECRET_KEY and admin password
#
# 4) Run with Docker Compose
#    docker compose up --build -d
