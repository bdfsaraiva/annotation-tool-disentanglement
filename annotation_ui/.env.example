# Frontend configuration - Annotation UI
# ======================================

# Backend API URL
# Local development (backend on same machine)
REACT_APP_API_URL=http://localhost:8000

# Remote backend example
# REACT_APP_API_URL=http://192.168.1.100:8000

# ======================================
# Usage
# ======================================
# 1) Copy this file to .env
#    cp .env.example .env
#
# 2) Update REACT_APP_API_URL if the backend runs on another machine
#
# 3) Restart the frontend after editing .env
#    npm start
