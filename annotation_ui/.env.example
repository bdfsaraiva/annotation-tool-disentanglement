# Frontend configuration - Annotation UI
# ======================================

# Backend API URL (explicit per environment)
VITE_API_URL=http://localhost:8000

# ======================================
# Usage
# ======================================
# 1) Copy this file to .env
#    cp .env.example .env
#
# 2) Update VITE_API_URL to the backend URL for the environment
#
# 3) Restart the frontend after editing .env
#    npm start
